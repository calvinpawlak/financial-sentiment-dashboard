# Copy this file to `.env` and fill in your own values.
# Never commit the real .env file.

# Register a free "script" app at https://www.reddit.com/prefs/apps
# to get these two values.
REDDIT_CLIENT_ID=your_client_id_here
REDDIT_CLIENT_SECRET=your_client_secret_here

# Register a free API key at https://finnhub.io/register for company news
# + aggregated Reddit/Twitter social sentiment (this is what gives the
# pipeline a Reddit/Twitter-adjacent signal without needing our own gated
# Reddit API access). If left blank or as this placeholder, Finnhub
# ingestion is skipped cleanly each cycle - nothing else is affected.
FINNHUB_API_KEY=your_finnhub_api_key_here

# Free Bluesky account credentials. Generate an app password in Bluesky
# Settings -> Privacy and Security -> App passwords. Do not use your primary
# account password here.
BLUESKY_HANDLE=your_bluesky_handle_here
BLUESKY_APP_PASSWORD=your_bluesky_app_password_here

# Required by SEC fair-access policy; identify your app and contact email.
SEC_USER_AGENT=Financial Sentiment Dashboard your_email@example.com
